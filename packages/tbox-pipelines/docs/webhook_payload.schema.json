{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/coolge101/tbox-ragflow/blob/main/packages/tbox-pipelines/docs/webhook_payload.schema.json",
  "title": "TBOX pipeline webhook POST body",
  "oneOf": [
    { "$ref": "#/definitions/tbox_sync_summary" },
    { "$ref": "#/definitions/tbox_rbac_alert" }
  ],
  "definitions": {
    "envelope": {
      "type": "object",
      "required": ["payload_version", "type", "status", "sync_id"],
      "properties": {
        "payload_version": {
          "type": "integer",
          "description": "Must match WEBHOOK_PAYLOAD_VERSION in notify.py (currently 1)."
        },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "sync_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "tbox_sync_summary": {
      "allOf": [
        { "$ref": "#/definitions/envelope" },
        {
          "type": "object",
          "required": ["type", "summary"],
          "properties": {
            "type": { "const": "tbox_sync_summary" },
            "summary": {
              "type": "object",
              "description": "Mirror of sync audit / sync_summary fields."
            }
          }
        }
      ]
    },
    "tbox_rbac_alert": {
      "allOf": [
        { "$ref": "#/definitions/envelope" },
        {
          "type": "object",
          "required": ["type", "rbac"],
          "properties": {
            "type": { "const": "tbox_rbac_alert" },
            "rbac": {
              "type": "object",
              "description": "RBAC audit event plus optional rbac_alert_suppressed_in_window."
            }
          }
        }
      ]
    }
  }
}
