{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alert docs gate rules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "required_example_files",
    "required_changelog_stage_tokens",
    "examples_readme_required_tokens"
  ],
  "properties": {
    "required_example_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_changelog_stage_tokens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage",
          "evidence_tokens"
        ],
        "properties": {
          "stage": {
            "type": "string",
            "pattern": "^S[0-9]+\\.[0-9]+$"
          },
          "evidence_tokens": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "examples_readme_required_tokens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
